NODE_ENV=development
PORT=5111
JWT_SECRET=secret_super_seguro_produccion
API_KEY=api_key_produccion # MISMA clave que Laravel Backend
# ALLOWED_ORIGINS=https://whatsapp.digimedia-marketing.com # Frontend producción
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
BASE_URL=http://localhost:5111 #RUTA BACKEND

# URL del Laravel Backend (para validación de tokens)
MAIN_BACKEND_URL=http://127.0.0.1:8000 # URL real del backend


# Auto-refresh WhatsApp session on server start
# Si está en 'true', el servicio intentará reconectar automáticamente si existen credenciales
AUTO_REFRESH_SESSION=true
MAX_RECONNECT_ATTEMPTS=3 #numero de intentos de reconexion
RECONNECT_TIMEOUT=30000
RECONNECT_COOLDOWN=10000


# Health Check de WhatsApp (previene falsos positivos)
WHATSAPP_HEALTH_CHECK=true
HEALTH_CHECK_TIMEOUT=5000

# N8N integration (MVP WhatsApp incoming flow)
N8N_WEBHOOK_URL=https://n8n.digimedia-marketing.com/webhook-test/chatbot
N8N_TIMEOUT_MS=12000
N8N_MAX_RETRIES=2
N8N_RETRY_DELAY_MS=1000
N8N_FALLBACK_MESSAGE=Disculpa, en este momento no puedo responder. Intenta nuevamente en unos minutos.